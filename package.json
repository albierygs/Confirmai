{
  "name": "confirma-ai",
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter api run build && pnpm --filter web run build",
    "dev": "pnpm --parallel --filter api --filter web run dev",
    "lint": "pnpm --filter web run lint",
    "clean": "echo clean-not-configured",
    "test": "pnpm --filter api run test"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.25",
    "@types/supertest": "^6.0.3",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "supertest": "^7.1.4",
    "turbo": "^2.9.6"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "pnpm": "^10.30.2",
    "qrcode": "^1.5.4",
    "uuid": "^13.0.0"
  }
}
