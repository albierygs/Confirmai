// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Definição dos enums

enum EventoStatus {
  ativo
  encerrado
  rascunho
}

enum CargoUsuario {
  membro
  admin
  global_admin
}

enum InscricaoStatus {
  pendente
  confirmada
  cancelada
}

enum TenantStatus {
  ativo
  cancelado
  suspenso
}

enum TicketStatus {
  VALID
  USED
  CANCELED
  REFUNDED
}

enum StripeAccountType {
  STANDARD
  EXPRESS
  CUSTOM
}

enum StripeAccountStatus {
  PENDING
  ENABLED
  DISABLED
  RESTRICTED
}

enum StripeAccountBusinessType {
  INDIVIDUAL
  COMPANY
}

enum OrderStatus {
  PENDING // Aguardando pagamento
  PROCESSING // Processando pagamento
  PAID // Pago
  CONFIRMED // Confirmado (tickets gerados)
  EXPIRED // Expirado (PIX/Boleto)
  FAILED // Falha no pagamento
  CANCELED // Cancelado pelo usuário/admin
  REFUNDED // Reembolsado
  PARTIAL_REFUND // Reembolso parcial
}

enum PaymentMethodTypes {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
  WALLET // Apple Pay, Google Pay
}

enum ReservationStatus {
  ACTIVE // Reserva ativa
  EXPIRED // Expirou
  CONVERTED // Convertida em compra
  CANCELLED // Cancelada pelo usuário
}

enum SubscriptionStatus {
  ACTIVE // Assinatura ativa
  PAST_DUE // Pagamento atrasado (grace period de 3 dias)
  CANCELED // Cancelada pelo tenant
  EXPIRED // Expirou sem renovação
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

// Definição dos modelos

model tenants {
  id         String       @id @default(uuid())
  nome       String
  cnpj       String       @unique @db.VarChar(14)
  telefone   String       @db.VarChar(20)
  email      String       @unique
  site       String?
  slug       String       @unique // para subdomínio: empresa.seuapp.com
  status     TenantStatus @default(ativo) // ativo, suspenso, cancelado
  createdAt  DateTime     @default(now()) @map("created_at")
  updated_at DateTime     @updatedAt @map("updated_at")

  // Configurações
  logoUrl String? @map("logo_url")

  // Relacionamentos
  usuarios      usuarios[]
  eventos       eventos[]
  stripeAccount StripeAccount?
  orders        Order[]
  reservations  Reservation[]
  subscriptions Subscription[]
}

model eventos {
  id          String       @id @default(uuid())
  tenantId    String       @map("tenant_id")
  titulo      String
  descricao   String?      @db.Text
  linkSlug    String       @unique @map("link_slug")
  startDate   DateTime     @default(now()) @map("start_date")
  closingDate DateTime     @map("closing_date")
  location    String?
  status      EventoStatus @default(ativo)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant  tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches Batch[]
  // orders  Order[]
  tickets Ticket[]

  @@unique([tenantId, linkSlug])
}

model Batch {
  id          String   @id @default(uuid())
  eventId     String
  name        String // "1º Lote", "2º Lote", "Lote VIP"
  description String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(true) @map("is_active")
  order       Int      @default(0) // Ordem de exibição
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event        eventos       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  batchTickets BatchTicket[]

  @@index([eventId])
  @@map("batches")
}

model TicketType {
  id          String   @id @default(uuid())
  name        String // "Inteira", "Meia", "VIP"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  batchTickets BatchTicket[]

  @@map("ticket_types")
}

model BatchTicket {
  id               String   @id @default(uuid())
  batchId          String   @map("batch_id")
  ticketTypeId     String   @map("ticket_type_id")
  price            Decimal  @db.Decimal(19, 4) // Preço do ingresso
  quantity         Int // Quantidade disponível
  soldQuantity     Int      @default(0) @map("sold_quantity")
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  batch              Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  ticketType         TicketType          @relation(fields: [ticketTypeId], references: [id])
  tickets            Ticket[]
  orderItems         OrderItem[]
  reservationTickets ReservationTicket[]

  @@unique([batchId, ticketTypeId])
  @@index([batchId])
  @@map("batch_tickets")
}

model Ticket {
  id            String @id @default(uuid())
  orderId       String @map("order_id")
  eventId       String @map("event_id")
  userId        String @map("user_id")
  batchTicketId String @map("batch_ticket_id")

  hash   String       @unique // Hash único para QR Code
  price  Decimal      @db.Decimal(19, 4)
  status TicketStatus @default(VALID)

  checkedInAt DateTime?
  checkedInBy String? // User/Staff que fez check-in

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event         eventos     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  usuario       usuarios    @relation("owner", fields: [userId], references: [id])
  batchTicket   BatchTicket @relation(fields: [batchTicketId], references: [id])
  checkedInUser usuarios?   @relation("checked-in", fields: [checkedInBy], references: [id])

  @@index([orderId])
  @@index([eventId])
  @@index([hash])
  @@map("tickets")
}

model usuarios {
  id        String       @id @default(uuid())
  tenantId  String?      @map("tenant_id")
  nome      String
  email     String
  senhaHash String       @map("senha_hash")
  cargo     CargoUsuario @default(membro)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant         tenants?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders         Order[]
  checkedTickets Ticket[]      @relation("checked-in")
  tickets        Ticket[]      @relation("owner")
  reservations   Reservation[]

  @@unique([tenantId, email])
}

model PaymentProvider {
  id       String  @id @default(uuid())
  slug     String  @unique // "stripe", "mercadopago", "asaas"
  isActive Boolean @default(true)

  // Comissão da plataforma (aplicada sobre o valor do ingresso)
  platformFeePercent   Decimal @default(10) @db.Decimal(5, 2)
  platformCoustPercent Decimal @default(5) @db.Decimal(5, 2) // Custo operacional da plataforma (ex: taxas do stripe)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentMethods PaymentMethod[]

  @@map("payment_providers")
}

model PaymentMethod {
  id         String @id @default(uuid())
  providerId String

  // Identificação
  slug String @unique // "credit_card", "debit_card", "pix", "boleto"
  name String // "Cartão de Crédito", "PIX", "Boleto"

  // Taxas do gateway (cobradas pelo Stripe, MP, etc)
  gatewayFeePercent Decimal @db.Decimal(5, 2) // Ex: 3.99% (Stripe)
  gatewayFeeFixed   Decimal @db.Decimal(10, 2) // Ex: R$ 0,39

  // Parcelamento (para cartões)
  allowInstallments   Boolean @default(false)
  maxInstallments     Int     @default(3)
  minInstallmentValue Decimal @default(100) @db.Decimal(10, 2)
  interestFree        Int     @default(1) // Parcelas sem juros
  interestRate        Decimal @default(0) @db.Decimal(5, 2) // Taxa de juros ao mês

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, slug])
  @@index([providerId])
  @@index([slug])
  @@map("payment_methods")
}

model StripeAccount {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")

  // Dados da conta Stripe Connect
  accountId     String              @unique @map("account_id") // acc_xxxxx 
  accountType   StripeAccountType   @default(STANDARD) @map("account_type")
  accountStatus StripeAccountStatus @default(PENDING) @map("account_status")

  // Status de ativação 
  detailsSubmitted Boolean @default(false) @map("details_submitted")
  chargesEnabled   Boolean @default(false) @map("charges_enabled")
  payoutsEnabled   Boolean @default(false) @map("payouts_enabled")

  // Dados adicionais
  country      String                     @default("BR")
  currency     String                     @default("brl")
  email        String?
  businessType StripeAccountBusinessType? @map("business_type") // individual, company

  // Timestamps importantes
  onboardedAt DateTime? @map("onboarded_at")
  lastSyncAt  DateTime? @map("last_sync_at")

  // Metadata
  requirementsData Json? @map("requirements_data") // Armazena requirements do Stripe
  capabilitiesData Json? @map("capabilities_data") // Armazena capabilities

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([tenantId])
  @@map("stripe_accounts")
}

model Order {
  id            String @id @default(uuid())
  tenantId      String @map("tenant_id")
  reservationId String @map("reservation_id")
  userId        String @map("user_id")

  // Valores monetários
  subtotal    Decimal @db.Decimal(19, 4) // Soma dos ingressos
  platformFee Decimal @map("platform_fee") @db.Decimal(19, 4) // Comissão da plataforma
  total       Decimal @db.Decimal(19, 4) // Total pago pelo cliente

  // Status do pedido
  status OrderStatus @default(PENDING)

  // Dados de pagamento
  paymentMethod   PaymentMethodTypes? @map("payment_method")
  paymentProvider String?             @default("stripe") @map("payment_provider") // stripe, mercadopago

  // Stripe específico
  stripeCheckoutSessionId String?  @unique @map("stripe_checkout_session_id")
  stripeTransferId        String?  @map("stripe_transfer_id") // ID da transferência para o tenant
  stripeApplicationFee    Decimal? @map("stripe_application_fee") @db.Decimal(19, 4) // Valor da application fee em centavos

  // URLs e dados extras
  paymentUrl    String? @map("payment_url") // Para PIX/Boleto
  qrCodeData    String? @map("qr_code_data") @db.Text // QR Code do PIX
  boletoBarcode String? @map("boleto_barcode")

  // Timestamps importantes
  paidAt      DateTime? @map("paid_at")
  confirmedAt DateTime? @map("confirmed_at")
  canceledAt  DateTime? @map("canceled_at")
  refundedAt  DateTime? @map("refunded_at")
  expiresAt   DateTime? @map("expires_at") // Para PIX/Boleto

  // Observações
  notes        String? @db.Text
  cancelReason String? @map("cancel_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações
  tenant      tenants      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  usuario     usuarios     @relation(fields: [userId], references: [id])
  tickets     Ticket[]
  orderItems  OrderItem[]

  @@index([tenantId])
  @@index([reservationId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// Itens do pedido (útil para rastreamento e relatórios)
model OrderItem {
  id            String @id @default(uuid())
  orderId       String @map("order_id")
  batchTicketId String @map("batch_ticket_id")

  // Dados no momento da compra (snapshot)
  ticketTypeName String  @map("ticket_type_name")
  batchName      String  @map("batch_name")
  quantity       Int
  price          Decimal @db.Decimal(19, 4) // Preço unitário
  total          Decimal @db.Decimal(19, 4) // quantity

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  batchTicket BatchTicket @relation(fields: [batchTicketId], references: [id])

  @@index([orderId])
  @@index([batchTicketId])
  @@map("order_items")
}

model Reservation {
  id String @id @default(uuid())

  // Uma reserva ativa por usuário e tenant (carrinho unificado)
  userId   String @map("user_id")
  tenantId String @map("tenant_id")

  // Expiração do carrinho (30 min a partir do 1º ingresso; +30 min ao iniciar checkout)
  expiresAt DateTime @map("expires_at")

  // Status
  status ReservationStatus @default(ACTIVE)

  // Metadata
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usuario usuarios            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets ReservationTicket[]
  orders  Order[]
  tenant  tenants             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@index([status])
  @@map("reservations")
}

// Linhas do carrinho: quantidade por tipo de ingresso (batch_ticket)
model ReservationTicket {
  id            String @id @default(uuid())
  reservationId String @map("reservation_id")
  batchTicketId String @map("batch_ticket_id")
  quantity      Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  batchTicket BatchTicket @relation(fields: [batchTicketId], references: [id], onDelete: Cascade)

  @@unique([reservationId, batchTicketId])
  @@index([batchTicketId])
  @@map("reservation_tickets")
}

model Plan {
  id          String       @id @default(uuid())
  name        String // "Mensal", "Anual"
  slug        String       @unique // "mensal", "anual"
  description String?
  interval    PlanInterval // MONTHLY, YEARLY
  price       Decimal      @db.Decimal(10, 2) // Preço em BRL
  isActive    Boolean      @default(true) @map("is_active")

  // Stripe Billing
  stripePriceId   String? @unique @map("stripe_price_id")
  stripeProductId String? @map("stripe_product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  planId   String @map("plan_id")

  status SubscriptionStatus @default(ACTIVE)

  // Datas
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  canceledAt DateTime? @map("canceled_at")
  cancelAtEnd Boolean  @default(false) @map("cancel_at_end") // Cancelar no final do período

  // Stripe Billing
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  stripeCustomerId     String? @map("stripe_customer_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant tenants @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan    @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("subscriptions")
}
